{
  "name": "@mindmaplib/core",
  "version": "0.0.0",
  "description": "Framework-agnostic mindmap engine: document model, transactions, layout, serialization, and storage.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewArto/mindmaplib.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/AndrewArto/mindmaplib/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/AndrewArto/mindmaplib/issues"
  },
  "keywords": [
    "mindmap",
    "mind-map",
    "diagram",
    "tree-layout",
    "typescript",
    "editor",
    "visualization"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "d3-hierarchy": "^3.1.0"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.0"
  }
}
